# ============================================================
# Webshop - environment template. Copy to .env and fill values.
# NEVER commit a real .env. Secrets are injected at runtime only.
# ============================================================

# --- Core ---
NODE_ENV=development

# --- API ---
API_PORT=4000
API_URL=http://localhost:4000

# --- Database (PostgreSQL) ---
# For local docker dev: postgres://webshop:webshop@localhost:5432/webshop
DATABASE_URL=postgresql://webshop:webshop@localhost:5432/webshop?schema=public
POSTGRES_USER=webshop
POSTGRES_PASSWORD=webshop
POSTGRES_DB=webshop

# --- Redis (cache + BullMQ) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Auth (generate strong random values, min 32 chars) ---
JWT_ACCESS_SECRET=change_me_min_32_chars_access_secret_value
JWT_REFRESH_SECRET=change_me_min_32_chars_refresh_secret_value
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# --- Encryption (AES-256-GCM master key, base64 of 32 bytes) ---
ENCRYPTION_MASTER_KEY=change_me_base64_32_byte_master_key_value

# --- Frontend origins (CORS) ---
STOREFRONT_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3001

# --- Frontend public ---
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Epusdt / GMPay (added in M2) ---
EPUSDT_BASE_URL=http://epusdt:8000
EPUSDT_PID=
EPUSDT_SECRET_KEY=
EPUSDT_NOTIFY_URL=http://localhost:4000/payments/epusdt/notify
EPUSDT_REDIRECT_URL=http://localhost:3000/orders
