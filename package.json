{
  "name": "webshop",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @webshop/database generate",
    "db:migrate": "pnpm --filter @webshop/database migrate",
    "db:seed": "pnpm --filter @webshop/database seed",
    "docker:dev": "docker compose -f docker-compose.dev.yml up -d",
    "docker:up": "docker compose up -d --build"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "prisma", "@prisma/engines", "argon2", "esbuild"]
  }
}
